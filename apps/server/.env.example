# --------------------------------------------------
# ARGON-V Server Environment Configuration
# Copy to .env.local and adjust as needed.
# --------------------------------------------------

# Server port (used by npm scripts / dev tooling)
PORT=3001

# MongoDB connection URI
# Local example:
MONGODB_URI=mongodb://127.0.0.1:27017/argonv

# Runtime mode
NODE_ENV=development

# HMAC secret used for challenge / attestation binding
# Generate with:
#   openssl rand -hex 32
CHALLENGE_HMAC_SECRET=changeme

# Base URL for the server (used by extensions / clients)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001